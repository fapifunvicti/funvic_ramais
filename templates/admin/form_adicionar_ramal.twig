{% extends "home.html.twig" %}


{% block titulo %} Adicionar um Novo Setor{% endblock %}
{% block topo %}a{% endblock %}


{% block conteudo %}
    <div class="container">
        <h3>Adicionar um Novo Ramal:</h3>
        <form action="" method="post">
            <div class="mb-3">
                <label class="label-control" for="nome">Nome:</label>
                <input class="form-control" type="text" placeholder="Nome do Setor" name="nome" id="nome">
            </div>
            <div class="mb-3 justify-content-center">
                 <button class="btn btn-lg btn-secondary">Adicionar</button>
            </div>
        </form>
    </div>
{% endblock %}