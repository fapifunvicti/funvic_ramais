{% extends "home.html.twig" %}


{% block titulo %} Adicionar um Novo Setor{% endblock %}
{% block topo %}a{% endblock %}


{% block conteudo %}
    <div class="container">
        <div class="mb-3">
            {% if tipo == "cadastro" %}
            <h3>Adicionar um Novo Setor:</h3>
            {% else %}
            <h4>Editar: {{ setores.nome }}</h4>
            {% endif %}
            <form action="" method="post">
                <div class="mb-3">
                    <label class="label-control" for="nome">Nome:</label>
                    <input class="form-control" value="{{ setores.nome }}" type="text" placeholder="Nome do Setor" name="nome" id="nome">
                </div>
                <div class="mb-3 justify-content-center">
                    <button class="btn btn-lg btn-secondary">{% if tipo is null %} Adicionar {% else %} Editar {{setores.nome}} {% endif %}</button>
                </div>
            </form>
        </div>
        <div class="mb-3" id="status">

        </div>

    {% if tipo == "cadastro" %}
        <div class="mb-3">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Inserido em:</th>
                        <th>Ativo</th>
                        <th>Administrativo:</th>
                    </tr>
                </thead>

                <tbody>
                    {% for setor in setores %}
                    <tr>
                        <td><a href="/admin/setor/editar/{{ setor.idsetor }}">{{ setor.nome }}</a></td>
                        <td>{{ setor.inserido_em|format_datetime(locale: 'pt_br', dateFormat: 'short') }}</td>
                        <td>{% if setor.deletado_em is null %} 
                            <p>SIM</p>
                            {% else %}
                               NÃO
                            {% endif %}

                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                <button class="btn btn-danger btn-sm" hx-swap="outerHTML" hx-target="#status" hx-post="/admin/setor/deletar/{{ setor.idsetor }}" ><i class="fa-solid fa-circle-minus"></i></button>
                                <button class="btn btn-secondary btn-sm"><i class="fa-regular fa-pen-to-square"></i></button>
                            </div>

                        </td>
                    </tr>
                    {% endfor %}
                </tbody>

                <tfoot>
                    <tr>
                        <th>Nome</th>
                        <th>Inserido em:</th>
                        <th>Ativo</th>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="d-flex justify-content-center">
            <nav aria-label="Page navigation example">
            <ul class="pagination">
                <li class="page-item"><a class="page-link" href="#">Previous</a></li>
                <li class="page-item"><a class="page-link" href="#">1</a></li>
                <li class="page-item"><a class="page-link" href="#">2</a></li>
                <li class="page-item"><a class="page-link" href="#">3</a></li>
                <li class="page-item"><a class="page-link" href="#">Next</a></li>
            </ul>
            </nav>
        </div>
        {% endif %}

    </div>

{% endblock %}